# ProjectFlow KE — Environment Variables Setup Guide
# Copy this file to .env.local for local development, or add these keys to Vercel Project Settings -> Environment Variables

# 1. Supabase Project URL (e.g. https://your-project-id.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# 2. Supabase Anon API Key (found in Supabase Dashboard -> Project Settings -> API)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
